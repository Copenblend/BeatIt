<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BeatIt.ViewModels"
        x:Class="BeatIt.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="BeatIt"
        Background="{StaticResource WorkbenchBackground}"
        Width="1280"
        Height="720"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="30">

    <Window.Styles>
        <!-- Base title bar button style -->
        <Style Selector="Button.titleBarButton">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource ForegroundDefault}" />
            <Setter Property="FontFamily" Value="{StaticResource CodiconFont}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="Button.titleBarButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource ButtonHoverBackground}" />
        </Style>

        <!-- Close button hover override -->
        <Style Selector="Button.titleBarCloseButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource CloseButtonHover}" />
        </Style>
    </Window.Styles>

    <!-- Top-level layout: TitleBar / Content / StatusBar -->
    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Row 0: Title Bar -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Background="{StaticResource WorkbenchBackground}" Height="30">

            <!-- Left: Icon placeholder + Menu placeholder -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="16" Height="16" Margin="8,0,0,0" />
                <ContentControl Name="MenuBarPlaceholder" Margin="4,0,0,0" />
            </StackPanel>

            <!-- Center: Drag region -->
            <Border Name="TitleBarDragRegion"
                    Grid.Column="1"
                    Background="Transparent"
                    IsHitTestVisible="True"
                    PointerPressed="TitleBarDragRegion_PointerPressed" />

            <!-- Right: Window chrome buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Stretch">
                <Button Name="MinimizeButton"
                        Classes="titleBarButton"
                        Content="&#xEBA8;"
                        Command="{Binding MinimizeCommand, Mode=OneWay}" />
                <Button Name="MaximizeRestoreButton"
                        Classes="titleBarButton"
                        Command="{Binding MaximizeRestoreCommand, Mode=OneWay}">
                    <Panel>
                        <TextBlock Text="&#xEBA7;"
                                   FontFamily="{StaticResource CodiconFont}"
                                   FontSize="16"
                                   IsVisible="{Binding !IsMaximized, Mode=OneWay}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="&#xEBA9;"
                                   FontFamily="{StaticResource CodiconFont}"
                                   FontSize="16"
                                   IsVisible="{Binding IsMaximized, Mode=OneWay}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Panel>
                </Button>
                <Button Name="CloseButton"
                        Classes="titleBarButton titleBarCloseButton"
                        Content="&#xEBAA;"
                        Command="{Binding CloseCommand, Mode=OneWay}" />
            </StackPanel>
        </Grid>

        <!-- Row 1: Middle content area -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,*">

            <!-- Activity Bar -->
            <Border Name="ActivityBarZone"
                    Grid.Column="0"
                    Background="{StaticResource WorkbenchBackground}"
                    Width="48" />

            <!-- Side Bar -->
            <Border Name="SideBarZone"
                    Grid.Column="1"
                    Background="{StaticResource WorkbenchBackground}"
                    Width="200" />

            <!-- Workspace + Panel split -->
            <Grid Grid.Column="2" RowDefinitions="*,Auto">

                <!-- Workspace -->
                <Border Name="WorkspaceZone"
                        Grid.Row="0"
                        Background="{StaticResource WorkspaceBackground}" />

                <!-- Panel -->
                <Border Name="PanelZone"
                        Grid.Row="1"
                        Background="{StaticResource WorkbenchBackground}"
                        Height="200" />
            </Grid>
        </Grid>

        <!-- Row 2: Status Bar -->
        <Border Name="StatusBarZone"
                Grid.Row="2"
                Background="{StaticResource WorkbenchBackground}"
                Height="22" />
    </Grid>
</Window>
