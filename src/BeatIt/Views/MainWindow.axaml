<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BeatIt.ViewModels"
        xmlns:views="using:BeatIt.Views"
        x:Class="BeatIt.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="BeatIt"
        Background="{StaticResource WorkbenchBackground}"
        Width="1280"
        Height="720"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="30">

    <Window.Styles>
        <!-- Resize grip hit area (wide, transparent) -->
        <Style Selector="Border.resizeGrip">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="SizeWestEast" />
        </Style>

        <!-- Resize grip visible line (1px, resting state) -->
        <Style Selector="Border.resizeGrip Border.resizeGripLine">
            <Setter Property="Background" Value="{StaticResource DividerColor}" />
        </Style>

        <!-- Resize grip visible line on hover -->
        <Style Selector="Border.resizeGrip:pointerover Border.resizeGripLine">
            <Setter Property="Background" Value="{StaticResource AccentColor}" />
        </Style>

        <!-- Resize grip visible line during drag -->
        <Style Selector="Border.resizeGrip.dragging Border.resizeGripLine">
            <Setter Property="Background" Value="{StaticResource AccentColor}" />
        </Style>

        <!-- Panel resize grip hit area -->
        <Style Selector="Border.panelResizeGrip">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="SizeNorthSouth" />
        </Style>
        <Style Selector="Border.panelResizeGrip Border.panelResizeGripLine">
            <Setter Property="Background" Value="{StaticResource DividerColor}" />
        </Style>
        <Style Selector="Border.panelResizeGrip:pointerover Border.panelResizeGripLine">
            <Setter Property="Background" Value="{StaticResource AccentColor}" />
        </Style>
        <Style Selector="Border.panelResizeGrip.dragging Border.panelResizeGripLine">
            <Setter Property="Background" Value="{StaticResource AccentColor}" />
        </Style>

        <!-- Base title bar button style -->
        <Style Selector="Button.titleBarButton">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource ForegroundDefault}" />
            <Setter Property="FontFamily" Value="{StaticResource CodiconFont}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="Button.titleBarButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource ButtonHoverBackground}" />
        </Style>

        <!-- Close button hover override -->
        <Style Selector="Button.titleBarCloseButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource CloseButtonHover}" />
        </Style>

        <!-- Collapsed panel chevron button -->
        <Style Selector="Button.panelChevronButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource IconDefault}" />
            <Setter Property="FontFamily" Value="{StaticResource CodiconFont}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
        </Style>
        <Style Selector="Button.panelChevronButton:pointerover">
            <Setter Property="Foreground" Value="{StaticResource IconHover}" />
        </Style>
        <Style Selector="Button.panelChevronButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </Window.Styles>

    <!-- Top-level layout: TitleBar / Content / StatusBar -->
    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Row 0: Title Bar -->
        <Border Grid.Row="0"
                BorderBrush="{StaticResource DividerColor}"
                BorderThickness="0,0,0,1">
        <Grid ColumnDefinitions="Auto,*,Auto" Background="{StaticResource WorkbenchBackground}" Height="30">

            <!-- Left: Icon placeholder + Menu Bar -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="16" Height="16" Margin="8,0,0,0" />
                <views:MenuBarView Name="MenuBarZone" DataContext="{Binding MenuBar}" Margin="4,0,0,0" />
            </StackPanel>

            <!-- Center: Drag region -->
            <Border Name="TitleBarDragRegion"
                    Grid.Column="1"
                    Background="Transparent"
                    IsHitTestVisible="True"
                    PointerPressed="TitleBarDragRegion_PointerPressed" />

            <!-- Right: Window chrome buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Stretch">
                <Button Name="MinimizeButton"
                        Classes="titleBarButton"
                        Content="&#xEABA;"
                        Command="{Binding MinimizeCommand, Mode=OneWay}" />
                <Button Name="MaximizeRestoreButton"
                        Classes="titleBarButton"
                        Command="{Binding MaximizeRestoreCommand, Mode=OneWay}">
                    <Panel>
                        <TextBlock Text="&#xEAB9;"
                                   FontFamily="{StaticResource CodiconFont}"
                                   FontSize="16"
                                   IsVisible="{Binding !IsMaximized, Mode=OneWay}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="&#xEABB;"
                                   FontFamily="{StaticResource CodiconFont}"
                                   FontSize="16"
                                   IsVisible="{Binding IsMaximized, Mode=OneWay}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Panel>
                </Button>
                <Button Name="CloseButton"
                        Classes="titleBarButton titleBarCloseButton"
                        Content="&#xEAB8;"
                        Command="{Binding CloseCommand, Mode=OneWay}" />
            </StackPanel>
        </Grid>
        </Border>

        <!-- Row 1: Middle content area -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,Auto,*">

            <!-- Activity Bar -->
            <views:ActivityBarView Name="ActivityBarZone"
                                   Grid.Column="0"
                                   DataContext="{Binding ActivityBar}" />

            <!-- Side Bar -->
            <views:SideBarView Name="SideBarZone"
                               Grid.Column="1"
                               DataContext="{Binding SideBar}"
                               Width="{Binding Width, Mode=OneWay}"
                               IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ActivityBar.IsSideBarVisible, Mode=OneWay}" />

            <!-- Resize grip (wide hit area with 1px visible divider) -->
            <Border Name="ResizeGrip"
                    Grid.Column="2"
                    Classes="resizeGrip"
                    Width="8"
                    IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ActivityBar.IsSideBarVisible, Mode=OneWay}"
                    PointerPressed="OnResizeGripPointerPressed"
                    PointerMoved="OnResizeGripPointerMoved"
                    PointerReleased="OnResizeGripPointerReleased">
                <Border Classes="resizeGripLine"
                        Width="1"
                        HorizontalAlignment="Right" />
            </Border>

            <!-- Workspace + Panel split -->
            <Grid Grid.Column="3" RowDefinitions="*,Auto,Auto">

                <!-- Workspace -->
                <Border Name="WorkspaceZone"
                        Grid.Row="0"
                        Background="{StaticResource WorkspaceBackground}" />

                <!-- Panel resize grip -->
                <Border Name="PanelResizeGrip"
                        Grid.Row="1"
                        Classes="panelResizeGrip"
                        Height="8"
                        IsVisible="{Binding Panel.IsVisible, Mode=OneWay}"
                        PointerPressed="OnPanelResizeGripPointerPressed"
                        PointerMoved="OnPanelResizeGripPointerMoved"
                        PointerReleased="OnPanelResizeGripPointerReleased">
                    <Border Classes="panelResizeGripLine"
                            Height="1"
                            VerticalAlignment="Top" />
                </Border>

                <!-- Panel -->
                <views:PanelView Name="PanelZone"
                                 Grid.Row="2"
                                 DataContext="{Binding Panel}"
                                 Height="{Binding Height, Mode=OneWay}"
                                 IsVisible="{Binding IsVisible, Mode=OneWay}" />

                <!-- Collapsed panel bar (shown when panel is hidden) -->
                <Border Name="CollapsedPanelBar"
                        Grid.Row="2"
                        Height="22"
                        Background="{StaticResource WorkbenchBackground}"
                        BorderBrush="{StaticResource DividerColor}"
                        BorderThickness="0,1,0,0"
                        IsVisible="{Binding !Panel.IsVisible, Mode=OneWay}">
                    <Button Classes="panelChevronButton"
                            Content="&#xEAB7;"
                            Command="{Binding Panel.TogglePanelCommand, Mode=OneWay}"
                            HorizontalAlignment="Left"
                            Margin="4,0,0,0" />
                </Border>
            </Grid>
        </Grid>

        <!-- Row 2: Status Bar -->
        <views:StatusBarView Name="StatusBarZone" Grid.Row="2" />
    </Grid>
</Window>
