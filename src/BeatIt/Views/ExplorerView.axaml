<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BeatIt.ViewModels"
             x:Class="BeatIt.Views.ExplorerView"
             x:DataType="vm:ExplorerViewModel"
             Background="Transparent"
             UseLayoutRounding="True">

    <UserControl.Styles>
        <!-- TreeView transparent background -->
        <Style Selector="TreeView">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <!-- TreeViewItem base styling -->
        <Style Selector="TreeViewItem" x:DataType="vm:FileTreeNodeViewModel">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <!-- Shrink built-in expand/collapse chevron to match tree font size -->
        <Style Selector="TreeViewItem /template/ ToggleButton#PART_ExpandCollapseChevron">
            <Setter Property="Width" Value="12" />
            <Setter Property="Height" Value="14" />
        </Style>
        <Style Selector="TreeViewItem /template/ ToggleButton#PART_ExpandCollapseChevron Path">
            <Setter Property="Width" Value="8" />
            <Setter Property="Height" Value="8" />
        </Style>

        <!-- Remove default selection background on the header content presenter -->
        <Style Selector="TreeViewItem:selected /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{StaticResource ButtonHoverBackground}" />
        </Style>

        <!-- Pointer-over styling -->
        <Style Selector="TreeViewItem:pointerover /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{StaticResource ButtonHoverBackground}" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="*">
        <TreeView ItemsSource="{Binding RootNodes, Mode=OneWay}">
            <TreeView.ItemTemplate>
                <TreeDataTemplate x:DataType="vm:FileTreeNodeViewModel"
                                  ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal"
                                Spacing="4"
                                Height="22"
                                VerticalAlignment="Center">
                        <!-- Directory row: folder icon + name -->
                        <Panel IsVisible="{Binding IsDirectory, Mode=OneTime}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <!-- Folder icon: closed when collapsed, open when expanded -->
                                <TextBlock FontFamily="{StaticResource CodiconFont}"
                                           FontSize="14"
                                           Foreground="{StaticResource IconDefault}"
                                           VerticalAlignment="Center"
                                           Text="&#xea83;"
                                           IsVisible="{Binding !IsExpanded}" />
                                <TextBlock FontFamily="{StaticResource CodiconFont}"
                                           FontSize="14"
                                           Foreground="{StaticResource IconDefault}"
                                           VerticalAlignment="Center"
                                           Text="&#xeaf7;"
                                           IsVisible="{Binding IsExpanded}" />

                                <!-- Directory name -->
                                <TextBlock Text="{Binding Name, Mode=OneTime}"
                                           Foreground="{StaticResource ForegroundDefault}"
                                           FontSize="13"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Panel>

                        <!-- File row: file icon + name -->
                        <Panel IsVisible="{Binding !IsDirectory}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock FontFamily="{StaticResource CodiconFont}"
                                           FontSize="14"
                                           Foreground="{StaticResource IconDefault}"
                                           VerticalAlignment="Center"
                                           Text="&#xea7b;" />

                                <!-- File name -->
                                <TextBlock Text="{Binding Name, Mode=OneTime}"
                                           Foreground="{StaticResource ForegroundDefault}"
                                           FontSize="13"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Panel>
                    </StackPanel>
                </TreeDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</UserControl>
