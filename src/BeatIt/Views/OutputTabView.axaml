<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BeatIt.ViewModels"
             xmlns:views="using:BeatIt.Views"
             x:Class="BeatIt.Views.OutputTabView"
             x:DataType="vm:OutputTabViewModel">

    <UserControl.Styles>
        <!-- Log level combo box styling -->
        <Style Selector="ComboBox.logLevelFilter">
            <Setter Property="Background" Value="#2D2D2D" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="Padding" Value="6,2" />
        </Style>

        <!-- ListBox: no selection chrome -->
        <Style Selector="ListBox.logEntryList">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="ListBox.logEntryList ListBoxItem">
            <Setter Property="Padding" Value="4,1" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="ListBox.logEntryList ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="ListBox.logEntryList ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">
        <!-- Filter bar -->
        <Border Grid.Row="0" Padding="8,4">
            <ComboBox Classes="logLevelFilter"
                      ItemsSource="{Binding AvailableLogLevels, Mode=OneWay}"
                      SelectedItem="{Binding SelectedLogLevel}" />
        </Border>

        <!-- Virtualized log entry list -->
        <ListBox Grid.Row="1"
                 Classes="logEntryList"
                 ItemsSource="{Binding FilteredEntries, Mode=OneWay}"
                 SelectionMode="Single">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:LogEntryViewModel">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding Timestamp, Mode=OneWay, StringFormat={}{0:HH:mm:ss.fff}}"
                                   FontFamily="Consolas"
                                   FontSize="10"
                                   Foreground="#CCCCCC" />
                        <TextBlock Text="{Binding Level, Mode=OneWay}"
                                   FontFamily="Consolas"
                                   FontSize="10"
                                   Foreground="{Binding Level, Mode=OneWay, Converter={x:Static views:LogLevelBrushConverter.Instance}}"
                                   Width="40" />
                        <TextBlock Text="{Binding Message, Mode=OneWay}"
                                   FontFamily="Consolas"
                                   FontSize="10"
                                   Foreground="#CCCCCC"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
